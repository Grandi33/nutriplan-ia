# Copia este archivo a .env.local y pon tu clave de Google AI Studio (Gemini).
# Es GRATIS: consíguela en https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...tu-clave...

# (Opcional) Modelo principal del plan semanal. Por defecto: gemini-2.5-flash.
# NUTRIPLAN_MODEL=gemini-2.5-flash

# (Opcional) Modelo para recetas y alternativas. Por defecto: gemini-2.5-flash.
# NUTRIPLAN_MODEL_FAST=gemini-2.5-flash
