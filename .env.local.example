# Copia este archivo a .env.local y pon tu clave real de Anthropic.
# Consíguela en https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (Opcional) Modelo principal del plan semanal. Por defecto: claude-sonnet-4-6.
# Para máxima calidad: claude-opus-4-8 (más caro y lento).
# NUTRIPLAN_MODEL=claude-sonnet-4-6

# (Opcional) Modelo barato para recetas y alternativas. Por defecto: Haiku.
# NUTRIPLAN_MODEL_FAST=claude-haiku-4-5-20251001
